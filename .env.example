# =============================================================
# LinkPortfolio — Variáveis de Ambiente (Vercel)
# =============================================================

# [OBRIGATÓRIA] Senha do painel administrativo (texto puro — hash gerado em runtime)
ADMIN_PASSWORD=suaSenhaSeguraAqui

# [OBRIGATÓRIA] URL de download direto do JSON no Google Drive
# Formato: https://drive.google.com/uc?export=download&id=SEU_FILE_ID
GOOGLE_DRIVE_JSON_URL=https://drive.google.com/uc?export=download&id=XXXXXXX

# [OBRIGATÓRIA] Secret para assinatura JWT (mínimo 32 caracteres)
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=cole-aqui-o-secret-gerado-com-32-chars-ou-mais

# [OPCIONAL] Tempo de vida do cache em memória (segundos). Padrão: 300 (5 min)
CACHE_TTL_SECONDS=300

# [OPCIONAL] URL pública do site (para Open Graph e QR Code)
NEXT_PUBLIC_SITE_URL=https://seu-dominio.vercel.app
